{
  "name": "website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "pnpm sanity:typegen",
    "dev": "SENTRY_SUPPRESS_TURBOPACK_WARNING=1 next dev --turbopack",
    "prebuild": "pnpm sanity:typegen",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "pull": "vercel env pull .env.local",
    "sanity:typegen": "pnpx sanity@latest schema extract --path=src/sanity/schema.json && pnpx sanity@latest typegen generate --config-path=src/sanity/sanity-typegen.json"
  },
  "dependencies": {
    "@sanity/asset-utils": "^2.3.0",
    "@sanity/client": "^7.22.0",
    "@sanity/icons": "^3.7.4",
    "@sanity/image-url": "^1.2.0",
    "@sanity/vision": "^3.99.0",
    "@sentry/nextjs": "^8.55.2",
    "@vercel/analytics": "^1.6.1",
    "flags": "^4.0.0",
    "@vercel/speed-insights": "^1.3.1",
    "@vercel/toolbar": "^0.2.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "import-in-the-middle": "^1.15.0",
    "next": "15.5.19",
    "next-sanity": "^9.12.3",
    "react": "19.2.7",
    "react-cookie": "^7.2.2",
    "react-dom": "19.2.7",
    "react-icons": "^5.6.0",
    "require-in-the-middle": "^7.5.2",
    "sanity": "^3.99.0",
    "statsig-node": "^6.5.1",
    "styled-components": "^6.4.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.5.19",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@9.15.9",
  "pnpm": {
    "pnpm": {
      "peerDependencyRules": {
        "allowAny": [
          "react",
          "react-dom"
        ]
      }
    }
  }
}
